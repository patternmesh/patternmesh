{
  "name": "@patternmeshjs/aws-sdk-v3",
  "version": "0.9.0",
  "description": "AWS SDK v3 DocumentClient adapter for @patternmeshjs/core.",
  "license": "Apache-2.0",
  "author": "patternmesh contributors",
  "homepage": "https://github.com/patternmesh/patternmesh/tree/main/packages/adapter-aws-sdk-v3#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patternmesh/patternmesh.git",
    "directory": "packages/adapter-aws-sdk-v3"
  },
  "bugs": {
    "url": "https://github.com/patternmesh/patternmesh/issues"
  },
  "keywords": [
    "dynamodb",
    "aws",
    "aws-sdk-v3",
    "adapter",
    "typescript",
    "esm",
    "patternmesh"
