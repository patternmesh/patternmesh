{
  "name": "@patternmeshjs/streams",
  "version": "0.9.0",
  "description": "Typed DynamoDB Streams decoding utilities for @patternmeshjs/core entities.",
  "license": "Apache-2.0",
  "author": "patternmesh contributors",
  "homepage": "https://github.com/patternmesh/patternmesh/tree/main/packages/streams#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patternmesh/patternmesh.git",
    "directory": "packages/streams"
  },
  "bugs": {
    "url": "https://github.com/patternmesh/patternmesh/issues"
  },
  "keywords": [
    "dynamodb",
    "dynamodb-streams",
    "aws",
    "aws-lambda",
    "typescript",
    "esm",
    "patternmesh"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/util-dynamodb": "^3.916.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.156",
    "@types/node": "^25.6.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
